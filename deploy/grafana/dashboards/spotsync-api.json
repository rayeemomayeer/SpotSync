      "title": "Oversell rejections / hr",
      "type": "timeseries",
      "targets": [
        {
          "expr": "increase(oversell_attempts_rejected_total[1h])",
          "legendFormat": "409 conflicts"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
