      "title": "Zone cache hit ratio",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(zone_availability_cache_hits_total[5m]) / (rate(zone_availability_cache_hits_total[5m]) + rate(zone_availability_cache_misses_total[5m]))",
