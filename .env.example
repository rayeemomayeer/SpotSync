# SpotSync — copy to .env and adjust for local development.
# The application fails fast on startup if required variables are missing.

# HTTP server
PORT=8080

# PostgreSQL (required)
DATABASE_URL=postgres://spotsync:spotsync@localhost:5432/spotsync?sslmode=disable

# JWT (required)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=24h

# Security
BCRYPT_COST=12
ALLOW_SELF_ADMIN_REGISTRATION=true

# CORS (comma-separated origins; empty = same-origin only)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database pool tuning
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Migrations (golang-migrate)
MIGRATE_ON_STARTUP=true
MIGRATIONS_PATH=migrations

# Logging
LOG_LEVEL=info

# Admin seed (make seed)
SEED_ADMIN_EMAIL=admin@spotsync.com
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ADMIN_NAME=Admin
