# SpotSync — copy to .env and adjust for local development.
# The application fails fast on startup if required variables are missing.

# HTTP server (use 8081 if Apache/XAMPP already binds 8080)
PORT=8081

# PostgreSQL (required)
DATABASE_URL=postgres://spotsync:spotsync@localhost:5432/spotsync?sslmode=disable

# Optional direct URL for golang-migrate (Neon: use non-pooled host for DDL).
# When unset, pooled Neon URLs auto-strip "-pooler." for migrations only.
# DATABASE_MIGRATE_URL=postgres://spotsync:spotsync@localhost:5432/spotsync?sslmode=disable

# JWT (required)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRY=24h

# Security
BCRYPT_COST=12
# Local/dev may set true for grading; production (Render) must be false — seed admins instead.
ALLOW_SELF_ADMIN_REGISTRATION=true

# Protect /metrics when set (Bearer or ?token=). Empty = open (local only).
METRICS_TOKEN=

# CORS (comma-separated origins; empty = allow all origins — tighten in production)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://spotsync-nu.vercel.app

# Database pool tuning
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# Migrations (golang-migrate)
MIGRATE_ON_STARTUP=true
MIGRATIONS_PATH=migrations

# Logging
LOG_LEVEL=info

# Demo reservations (portfolio showcase)
DEMO_RESERVATION_TTL=10m

# Redis (optional — enables cache + cross-replica SSE + outbox notify publish)
REDIS_URL=redis://localhost:6379/0

# Run outbox relay + reservation expiry inside the API process (no separate worker)
# EMBED_WORKER=true

# Tracing (optional — leave empty to disable)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# TLS hardening (set true when served over HTTPS)
# ENABLE_HSTS=true

# Feature flags (comma-separated enables)
# FEATURE_FLAGS=stripe_billing,org_search

# Admin seed (make seed)
SEED_ADMIN_EMAIL=admin@spotsync.com
SEED_ADMIN_PASSWORD=change-me-admin-password
SEED_ADMIN_NAME=Admin

# Render MCP (Cursor only — not read by the app)
# Create at https://dashboard.render.com/u/settings#api-keys
# RENDER_API_KEY=your-render-api-key
